@page "/details"
@inject JsHelper Js

<div class="import-page">
    <div class="container" style="max-width: 720px;">

        <div class="page-header">
            <h1>Details</h1>
            <p>Übersicht über Prüfungen und Teilnehmer</p>
        </div>

        <!-- Prüfungen -->
        <div class="panel">
            <button class="panel-header" type="button" @onclick="() => TogglePanel(1)">
                <div class="panel-header-left">
                    <div class="panel-icon panel-icon-blue">
                        <i class="bi bi-clipboard-check"></i>
                    </div>
                    <div>
                        <p class="panel-title">Prüfungen</p>
                        <p class="panel-subtitle">Alle vorhandenen Prüfungen im Lehrgang</p>
                    </div>
                </div>
                <i class="bi bi-chevron-down panel-chevron @(_openPanel == 1 ? "open" : "")"></i>
            </button>

            @if (_openPanel == 1)
            {
                <div class="panel-body">

                    @if (!(_currentCourse?.Exams?.Any() ?? false))
                    {
                        <div class="alert-custom alert-danger-custom">
                            Keine Prüfungen vorhanden
                        </div>
                    }
                    else
                    {
                        int index = 1;

                        <ul class="merge-file-list">
                            @foreach (var exam in _currentCourse!.Exams)
                            {
                                <li class="merge-file-item">
                                    <div class="merge-file-item-left">
                                        <i class="bi bi-file-earmark-text"></i>
                                        <div>
                                            <div class="merge-file-name">@index. @exam.Name</div>
                                            <div class="panel-subtitle">@exam.Description</div>
                                        </div>
                                    </div>
                                </li>
                                index++;
                            }
                        </ul>
                    }

                </div>
            }
        </div>

        <!-- Teilnehmer -->
        <div class="panel">
            <button class="panel-header" type="button" @onclick="() => TogglePanel(2)">
                <div class="panel-header-left">
                    <div class="panel-icon panel-icon-green">
                        <i class="bi bi-people"></i>
                    </div>
                    <div>
                        <p class="panel-title">Teilnehmer</p>
                        <p class="panel-subtitle">Alle Teilnehmer im Lehrgang</p>
                    </div>
                </div>
                <i class="bi bi-chevron-down panel-chevron @(_openPanel == 2 ? "open" : "")"></i>
            </button>

            @if (_openPanel == 2)
            {
                <div class="panel-body">

                    @if (!(_currentCourse?.Students?.Any() ?? false))
                    {
                        <div class="alert-custom alert-danger-custom">
                            Keine Teilnehmer vorhanden
                        </div>
                    }
                    else
                    {
                        int index = 1;

                        <ul class="merge-file-list">
                            @foreach (var student in _currentCourse!.Students)
                            {
                                <li class="merge-file-item">
                                    <div class="merge-file-item-left">
                                        <i class="bi bi-person"></i>
                                        <div>
                                            <div class="merge-file-name">
                                                @index. @student.FirstName @student.LastName
                                            </div>
                                            <div class="panel-subtitle">
                                                @student.Club · @student.DateOfBirth.ToString("dd.MM.yyyy")
                                            </div>
                                        </div>
                                    </div>
                                </li>
                                index++;
                            }
                        </ul>
                    }

                </div>
            }
        </div>

    </div>
</div>

@code {
    private Course? _currentCourse;
    private int _openPanel;

    protected override async Task OnInitializedAsync()
    {
        _currentCourse = await Js.GetItemFromLocalStorageAsync<Course>();
    }

    private void TogglePanel(int panelNumber)
    {
        _openPanel = _openPanel == panelNumber ? 0 : panelNumber;
    }
}