@page "/export"
@inject ExcelGradesExportService ExcelGradesExportService
@inject JsHelper Js

<div class="import-page">
    <div class="container" style="max-width: 720px;">

        <div class="page-header">
            <h1>Export</h1>
            <p>Noten als Excel-Datei exportieren</p>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-header-left">
                    <div class="panel-icon panel-icon-green">
                        <i class="bi bi-download"></i>
                    </div>
                    <div>
                        <p class="panel-title">Noten exportieren</p>
                        <p class="panel-subtitle">Speichert die Noten in einer Excel-Datei</p>
                    </div>
                </div>
            </div>

            <div class="panel-body">
                <div class="import-section">
                    <div class="import-section-text">
                        <h6>Export starten</h6>
                        <p>Prüfername eingeben und Datei herunterladen</p>
                    </div>

                    <button class="btn-action btn-primary-action"
                            @onclick="OpenExaminerModal">
                        <i class="bi bi-download"></i>
                        <span>Export</span>
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

@if (_showExaminerModal)
{
    <div class="custom-modal-overlay">
        <div class="custom-modal">

            <div class="custom-modal-header">
                <h5>Prüferdaten</h5>
                <button class="modal-close" @onclick="CloseExaminerModal">×</button>
            </div>

            <div class="custom-modal-body">

                <div class="alert-custom alert-success-custom">
                    <i class="bi bi-info-circle"></i>
                    Bitte Prüfernamen eingeben.
                </div>

                <div class="meta-info">
                    <div class="meta-row">
                        <strong>Name</strong>
                        <input type="text"
                               class="form-control"
                               placeholder="z.B. Max Mustermann"
                               @bind="_examinerName"
                               @bind:event="oninput"/>
                    </div>
                </div>

                @if (_showValidation && string.IsNullOrWhiteSpace(_examinerName))
                {
                    <div class="alert-custom alert-danger-custom">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Bitte Namen eingeben.
                    </div>
                }

            </div>

            <div class="custom-modal-footer">
                <button class="btn-action btn-outline-action" @onclick="CloseExaminerModal">
                    Abbrechen
                </button>

                <button class="btn-action btn-success-action"
                        @onclick="DownloadGrades"
                        disabled="@_isDownloading">
                    @if (_isDownloading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>Erstelle…</span>
                    }
                    else
                    {
                        <i class="bi bi-download"></i>
                        <span>Export</span>
                    }
                </button>
            </div>

        </div>
    </div>
}

@code {
    private Course? _currentCourse;
    private List<ExamResult> _examResults = [];

    private bool _isDownloading;
    private bool _showExaminerModal;
    private string _examinerName = string.Empty;
    private bool _showValidation;

    protected override async Task OnInitializedAsync()
    {
        _currentCourse = await Js.GetItemFromLocalStorageAsync<Course>();

        if (_currentCourse is null)
            return;

        _examResults = await Js.GetItemFromLocalStorageAsync<List<ExamResult>>(_currentCourse.MetaData.FileName) ?? [];
    }

    private void OpenExaminerModal()
    {
        ResetModal();
        _showExaminerModal = true;
    }

    private void CloseExaminerModal()
    {
        _showExaminerModal = false;
    }

    private void ResetModal()
    {
        _examinerName = string.Empty;
        _showValidation = false;
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_examinerName))
        {
            await DownloadGrades();
        }
    }

    private async Task DownloadGrades()
    {
        if (string.IsNullOrWhiteSpace(_examinerName))
        {
            _showValidation = true;
            return;
        }

        if (_currentCourse is null || !_examResults.Any())
            return;

        _isDownloading = true;

        try
        {
            var excelBytes = ExcelGradesExportService.GetFile(_currentCourse, _examResults, _examinerName);
            await Js.DownloadFileAsync(excelBytes, $"Noten-{_examinerName}.xlsx");

            CloseExaminerModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler beim Export: {ex.Message}");
        }
        finally
        {
            _isDownloading = false;
        }
    }
}