@page "/import"

@inject ExcelTemplateExportService ExcelTemplateExportService
@inject ExcelParseService ExcelParseService
@inject JsHelper Js
@inject RandomService Rnd

<div class="import-page">
    <div class="container" style="max-width: 720px;">

        <div class="page-header">
            <h1>Import & Verwaltung</h1>
            <p>Lehrgangsdaten importieren und Prüfungslisten verwalten</p>
        </div>

        <div class="panel">
            <button class="panel-header" type="button" @onclick="Toggle">
                <div class="panel-header-left">
                    <div class="panel-icon panel-icon-blue">
                        <i class="bi bi-file-earmark-spreadsheet"></i>
                    </div>
                    <div>
                        <p class="panel-title">Prüfungen</p>
                        <p class="panel-subtitle">Import & Prüfungslisten</p>
                    </div>
                </div>
            </button>

            @if (_open)
            {
                <div class="panel-body">

                    @if (_course != null)
                    {
                        <div class="stats-row">
                            <div class="stat-card">
                                <div class="stat-number blue">@_course.Students.Count</div>
                                <div class="stat-label">Teilnehmer</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-number green">@_course.Exams.Count</div>
                                <div class="stat-label">Prüfungen</div>
                            </div>
                        </div>

                        <div class="download-row">
                            <button class="btn-action btn-primary-action"
                                    @onclick="Download"
                                    disabled="@_downloading">
                                @(_downloading ? "..." : "Download Prüfungslisten")
                            </button>
                        </div>

                        <hr class="divider" />
                    }

                    <div class="import-section">
                        <div class="import-section-text">
                            <h6>Excel Import</h6>
                            <p>Teilnehmerdaten hochladen</p>
                        </div>

                        <button class="btn-action btn-success-action"
                                @onclick="Upload"
                                disabled="@_uploading">
                            @(_uploading ? "..." : "Import")
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(_msg))
                    {
                        <div class="alert-custom @( _ok ? "alert-success-custom" : "alert-danger-custom")">
                            @_msg
                        </div>
                    }

                </div>
            }
        </div>

    </div>
</div>

@code {
    private Course? _course;
    private bool _open = true;
    private bool _uploading;
    private bool _downloading;

    private string _msg = "";
    private bool _ok;

    protected override async Task OnInitializedAsync()
    {
        _course = await Js.GetItemFromLocalStorageAsync<Course>();
    }

    private void Toggle() => _open = !_open;

    private async Task Upload()
    {
        _uploading = true;
        _msg = "";

        try
        {
            var file = await Js.PickFileAsync();
            if (file is null) return;

            using var ms = new MemoryStream(file.GetBytes());
            _course = await ExcelParseService.ParseTemplate(ms);

            await Js.SetItemToLocalStorageAsync(_course);

            _msg = "Import OK";
            _ok = true;
        }
        catch (Exception ex)
        {
            _msg = ex.Message;
            _ok = false;
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task Download()
    {
        _downloading = true;

        try
        {
            Dictionary<string, List<Student>> data = [];

            foreach (var exam in _course?.Exams ?? [])
            {
                var seed = exam.Name + exam.Description;
                data.Add(exam.Name,
                    Rnd.Shuffle(_course!.Students.ToList(), seed));
            }

            var file = ExcelTemplateExportService.GenerateExamOrderTemplate(data);
            await Js.DownloadFileAsync(file, "Prüfungslisten.xlsx");
        }
        finally
        {
            _downloading = false;
        }
    }
}