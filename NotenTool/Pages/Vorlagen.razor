@page "/vorlagen"
@inject ExcelTemplateExportService ExcelTemplateExportService
@inject JsHelper Js

<div class="import-page">
    <div class="container" style="max-width: 720px;">

        <div class="page-header">
            <h1>Vorlagen</h1>
            <p>Excel-Vorlage für Teilnehmerdaten herunterladen</p>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div class="panel-header-left">
                    <div class="panel-icon panel-icon-blue">
                        <i class="bi bi-file-earmark-spreadsheet"></i>
                    </div>
                    <div>
                        <p class="panel-title">Teilnehmer-Vorlage</p>
                        <p class="panel-subtitle">
                            Excel herunterladen, ausfüllen und zur weiteren Verarbeitung nutzen
                        </p>
                    </div>
                </div>
            </div>

            <div class="panel-body">

                <div class="meta-info">
                    <div class="meta-row">
                        Vorlage enthält alle benötigten Felder für Teilnehmer und Prüfungen.
                    </div>
                    <div class="meta-row">
                        Kann an mehrere Prüfer verteilt und später wieder importiert werden.
                    </div>
                </div>

                <div class="import-section">
                    <div class="import-section-text">
                        <h6>Download starten</h6>
                        <p>Leere Excel-Vorlage herunterladen</p>
                    </div>

                    <button class="btn-action btn-primary-action"
                            @onclick="DownloadTemplate"
                            disabled="@_isDownloading">
                        @if (_isDownloading)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span>Erstelle…</span>
                        }
                        else
                        {
                            <i class="bi bi-download"></i>
                            <span>Download</span>
                        }
                    </button>
                </div>

            </div>
        </div>

    </div>
</div>

@code {
    private bool _isDownloading;

    private async Task DownloadTemplate()
    {
        _isDownloading = true;

        try
        {
            var fileBytes = ExcelTemplateExportService.GenerateEmptyTemplate();
            await Js.DownloadFileAsync(fileBytes, "Prüfungsvorlage.xlsx");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            _isDownloading = false;
        }
    }
}